events {
    worker_connections 1024;
}

http {
   map $subdomain $upstream {
    907817e5e4e123ffbfd11011bfb3e440266813dae09f32b20128b470ebe14b52   http://172.25.96.1:4000;
    409decfd64994d8f1ef9a74baebc43eb7f85f262d2c6c4c31d405b9e203e157d   http://172.25.96.1:4001;
    default "";
}

server {
    listen 8000;
    server_name ~^(?<subdomain>[^.]+)\.http://172.25.96.1;

    location / {
        if ($upstream = "") {
            return 200 "No such subdomain";
        }
        proxy_pass $upstream;
    }
}
}