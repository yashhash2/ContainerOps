events {
    worker_connections 1024;
}

http {
   map $subdomain $upstream {
    eac14b8e41b7713c02b7a5300704c6800dd34c08a3312842724dd2c99c5038d6   http://172.25.96.1:4000;
    default "";
}

server {
    listen 8000;
    server_name ~^(?<subdomain>[^.]+)\.http://172.25.96.1;

    location / {
        if ($upstream = "") {
            return 200 "No such subdomain";
        }
        proxy_pass $upstream;
    }
}
}